{
  "name": "mindease-web",
  "version": "1.0.0",
  "description": "MindEase - Plataforma de Acessibilidade Cognitiva",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install && npm run install:host && npm run install:painel && npm run install:tarefas && npm run install:perfil && npm run install:shared",
    "install:host": "cd packages/host && npm install",
    "install:painel": "cd packages/painel-cognitivo && npm install",
    "install:tarefas": "cd packages/organizador-tarefas && npm install",
    "install:perfil": "cd packages/perfil-usuario && npm install",
    "install:shared": "cd packages/shared && npm install",
    "dev": "concurrently --kill-others-on-fail --prefix-colors \"cyan,magenta,yellow,green\" --names \"HOST,PAINEL,TAREFAS,PERFIL\" \"npm run dev:host\" \"npm run dev:painel\" \"npm run dev:tarefas\" \"npm run dev:perfil\"",
    "dev:host": "cd packages/host && npm run dev",
    "dev:painel": "cd packages/painel-cognitivo && npm run dev",
    "dev:tarefas": "cd packages/organizador-tarefas && npm run dev",
    "dev:perfil": "cd packages/perfil-usuario && npm run dev",
    "build": "npm run build:shared && npm run build:painel && npm run build:tarefas && npm run build:perfil && npm run build:host",
    "build:host": "cd packages/host && npm run build",
    "build:painel": "cd packages/painel-cognitivo && npm run build",
    "build:tarefas": "cd packages/organizador-tarefas && npm run build",
    "build:perfil": "cd packages/perfil-usuario && npm run build",
    "build:shared": "cd packages/shared && npm run build",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
