{
  "name": "mindease-mobile",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "node node_modules/expo/bin/cli start",
    "tunnel": "node node_modules/expo/bin/cli start --tunnel",
    "android": "node node_modules/expo/bin/cli start --android",
    "ios": "node node_modules/expo/bin/cli start --ios",
    "web": "node node_modules/expo/bin/cli start --web",
    "test": "jest --watchAll=false",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~54.0.0",
    "expo-constants": "~17.0.5",
    "expo-font": "~13.3.0",
    "expo-secure-store": "~14.2.0",
    "expo-splash-screen": "~0.29.22",
    "expo-status-bar": "~2.2.0",
    "firebase": "^10.12.0",
    "react": "18.3.1",
    "react-native": "0.77.1",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.0",
    "@testing-library/react-native": "^12.4.5",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "~5.7.2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/(?!modules-core)|@expo-google-fonts|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/__tests__/**",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 60,
        "functions": 70,
        "lines": 70
      }
    },
    "moduleNameMapper": {
      "^firebase/app$": "<rootDir>/src/__mocks__/firebaseMock.ts",
      "^firebase/auth$": "<rootDir>/src/__mocks__/firebaseMock.ts",
      "^firebase/firestore$": "<rootDir>/src/__mocks__/firebaseMock.ts",
      ".*config/firebase$": "<rootDir>/src/__mocks__/firebaseMock.ts"
    },
    "setupFilesAfterFramework": [
      "@testing-library/react-native/extend-expect"
    ]
  },
  "private": true
}
